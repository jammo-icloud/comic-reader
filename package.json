{
  "name": "comic-reader",
  "version": "3.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "scan": "tsx src/server/scan-cli.ts"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "cookie-parser": "^1.4.7",
    "express": "^5.1.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.7.0",
    "multer": "^2.1.1",
    "mupdf": "^1.27.0",
    "node-unrar-js": "^2.0.2",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.10.38",
    "sharp": "^0.34.1",
    "unzipper": "^0.12.3",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-window": "^7.4.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/unzipper": "^0.10.11",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "pdf-lib": "^1.17.1",
    "postcss": "^8.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.5.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.2"
  }
}
